[1.504, "o", "\r\n\u001b[1mв”Ђв”Ђ Step 2: Launch Swank server on port 14006\u001b[0m\r\n\u001b[36m\u001b[36mв†’\u001b[0m\u001b[0m {\r\n  \"method\": \"tools/call\",\r\n  \"params\": {\r\n    \"name\": \"swank_launch\",\r\n    \"arguments\": {\r\n      \"port\": 14006\r\n    }\r\n  }\r\n}\r\n"]
[4.064, "o", "\u001b[32mв†ђ (SUCCESS T PORT 14006 PID 648771 MESSAGE\r\n SBCL+Swank running on port 14006 (pid 648771, style :spawn))\u001b[0m\r\n"]
[1.501, "o", "\r\n\u001b[1mв”Ђв”Ђ Step 3: Connect REPL to Swank\u001b[0m\r\n\u001b[36m\u001b[36mв†’\u001b[0m\u001b[0m {\r\n  \"method\": \"tools/call\",\r\n  \"params\": {\r\n    \"name\": \"repl_connect\",\r\n    \"arguments\": {\r\n      \"port\": 14006\r\n    }\r\n  }\r\n}\r\n"]
